POSTGRES_DB=crm
POSTGRES_USER=crm
POSTGRES_PASSWORD=change-me
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
# Optional: DATABASE_URL=postgres://crm:change-me@127.0.0.1:5432/crm

DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=crm.example.com
DJANGO_TIME_ZONE=Asia/Shanghai
DJANGO_LOG_LEVEL=INFO

# Optional DingTalk settings
# Internal app OpenAPI token for Todo v1.0 is fetched via:
# POST https://api.dingtalk.com/v1.0/oauth2/accessToken
# payload: {"appKey": DINGTALK_CLIENT_ID, "appSecret": DINGTALK_CLIENT_SECRET}
# DINGTALK_CORP_ID is not required for this token path (can still be kept for other APIs).
# DINGTALK_WEBHOOK=
# DINGTALK_CLIENT_ID=
# DINGTALK_CLIENT_SECRET=
# DINGTALK_CORP_ID=
# DINGTALK_TOKEN_URL=
# DINGTALK_USERINFO_URL=
# DINGTALK_ACCESS_TOKEN=
# DINGTALK_DEPT_LIST_URL=
# DINGTALK_DEPT_DETAIL_URL=
# DINGTALK_USER_LIST_URL=
# DINGTALK_SYNC_FILE=
# DINGTALK_TODO_ENABLED=0
# DINGTALK_TODO_RETRY_ENABLED=0
# DINGTALK_TODO_CREATE_URL=
# DINGTALK_TODO_COMPLETE_URL=
# DINGTALK_TODO_OPERATOR_UNION_ID=
# DINGTALK_OWN_OA_PROCESS_CODE=
# DINGTALK_OWN_OA_CREATE_URL=
# DINGTALK_OWN_OA_FORM_LABEL=审批详情
# FRONTEND_BASE_URL=http://127.0.0.1:5173/app
#
# Internal app (OpenAPI v1.0) typically uses api.dingtalk.com/v1.0 endpoints.
